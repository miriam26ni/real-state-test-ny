    function renderQuiz() {
      const quizDiv = document.getElementById('quiz');
      let html = '';

      fullQuestions.forEach(q => {
        html += `
          <div class="question" id="q${q.num}">
            <div class="question-number">Pregunta ${q.num}</div>
            <p><strong>${q.q}</strong></p>
            <div class="options">
              <div class="option" data-q="${q.num}" data-answer="a" onclick="selectAnswer(this)">a) ${q.a}</div>
              <div class="option" data-q="${q.num}" data-answer="b" onclick="selectAnswer(this)">b) ${q.b}</div>
              <div class="option" data-q="${q.num}" data-answer="c" onclick="selectAnswer(this)">c) ${q.c}</div>
              <div class="option" data-q="${q.num}" data-answer="d" onclick="selectAnswer(this)">d) ${q.d}</div>
            </div>
          </div>`;
      });

      quizDiv.innerHTML = html;
    }

    function selectAnswer(element) {
      const questionNum = parseInt(element.dataset.q);
      const selectedAnswer = element.dataset.answer;
      const correctAnswer = correctAnswers[questionNum];

      const options = element.parentElement.children;

      // Deshabilitar más clics
      Array.from(options).forEach(opt => {
        opt.style.pointerEvents = 'none';
      });

      if (selectedAnswer === correctAnswer) {
        element.classList.add('correct');
      } else {
        element.classList.add('wrong');
        // Marcar la correcta
        Array.from(options).forEach(opt => {
          if (opt.dataset.answer === correctAnswer) {
            opt.classList.add('correct');
          }
        });
      }
    }

    function calcularResultado() {
      let correctCount = 0;
      const total = 75;

      for (let i = 1; i <= total; i++) {
        const questionDiv = document.getElementById(`q${i}`);
        if (questionDiv) {
          const correctOption = questionDiv.querySelector(`.option[data-answer="${correctAnswers[i]}"]`);
          if (correctOption && correctOption.classList.contains('correct')) {
            correctCount++;
          }
        }
      }

      const percentage = Math.round((correctCount / total) * 100);
      let message = '';

      if (percentage >= 80) message = "¡Excelente! Estás bien preparado.";
      else if (percentage >= 70) message = "¡Bien! Pero necesitas repasar algunas áreas.";
      else message = "Necesitas estudiar más. ¡Tú puedes!";

      alert(`🎯 Resultado Final:\n\nCorrectas: ${correctCount} de ${total}\nPorcentaje: ${percentage}%\n\n${message}`);
    }

    // Iniciar la página
    window.onload = renderQuiz;
